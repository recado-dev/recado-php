{
    "name": "recado/recado-php",
    "description": "Official PHP SDK for the Recado REST API v1.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/recado-dev/recado-php",
    "keywords": [
        "recado",
        "email",
        "sdk",
        "api",
        "transactional"
    ],
    "support": {
        "issues": "https://github.com/recado-dev/recado-php/issues",
        "source": "https://github.com/recado-dev/recado-php"
    },
    "require": {
        "php": ">=8.3",
        "guzzlehttp/guzzle": "^7"
    },
    "require-dev": {
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "illuminate/mail": "^11.0||^12.0||^13.0",
        "illuminate/notifications": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0",
        "orchestra/testbench": "^9.0||^10.0||^11.0",
        "phpunit/phpunit": "^11.0||^12.0",
        "symfony/mailer": "^7.0"
    },
    "suggest": {
        "laravel/framework": "Required only for the Laravel integration (mail transport, notification channel, facade) — ^11.0||^12.0||^13.0"
    },
    "autoload": {
        "psr-4": {
            "Recado\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Recado\\Sdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Recado\\Sdk\\Laravel\\RecadoServiceProvider"
            ],
            "aliases": {
                "Recado": "Recado\\Sdk\\Laravel\\Facades\\Recado"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
