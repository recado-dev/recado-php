{
    "name": "mailer/mailer-php",
    "description": "Official PHP SDK for the Mailer REST API v1.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "mailer",
        "email",
        "sdk",
        "api",
        "transactional"
    ],
    "require": {
        "php": ">=8.2",
        "guzzlehttp/guzzle": "^7"
    },
    "require-dev": {
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "illuminate/mail": "^11.0||^12.0||^13.0",
        "illuminate/notifications": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0",
        "orchestra/testbench": "^9.0||^10.0||^11.0",
        "phpunit/phpunit": "^11||^12",
        "symfony/mailer": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Mailer\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mailer\\Sdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mailer\\Sdk\\Laravel\\MailerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
